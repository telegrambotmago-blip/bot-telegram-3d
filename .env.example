# Variáveis de Ambiente - Bot Telegram 3D
# Copie este arquivo para .env e preencha com seus valores reais
# NÃO COMMITE o arquivo .env com valores reais no Git!

# ============================================================================
# TELEGRAM
# ============================================================================
# Token do seu bot do Telegram
# Obtenha em: https://t.me/BotFather
TELEGRAM_TOKEN=seu_token_aqui_exemplo_123456789:ABCDefGHIJKlmnoPQRstUVwxyz

# ============================================================================
# GOOGLE GEMINI (Opcional, mas recomendado)
# ============================================================================
# Chave da API Google Gemini para geração de conteúdo
# Obtenha em: https://ai.google.dev/
GEMINI_API_KEY=sua_chave_gemini_aqui

# ============================================================================
# ALIEXPRESS AFFILIATE API
# ============================================================================
# Credenciais da API de Afiliados do AliExpress
# Obtenha em: https://portals.aliexpress.com/

# Chave da aplicação (App Key)
ALI_APP_KEY=sua_app_key_aqui

# Secret da aplicação (App Secret)
ALI_APP_SECRET=seu_app_secret_aqui

# ID de rastreamento para comissões
ALI_TRACKING_ID=seu_tracking_id_aqui

# ============================================================================
# CONFIGURAÇÃO DO BOT (Opcional)
# ============================================================================
# IDs dos canais/grupos onde o bot posta conteúdo
# Formato: @nome_do_canal ou -123456789 (ID numérico)

# Canal principal de destino para promoções
CANAL_PRINCIPAL=@gruposecretodomago

# Grupo para verificação de membros
GRUPO_META=@gruposecretodomago

# ID do admin (seu ID do Telegram)
# Obtenha digitando /id em qualquer chat com um bot
ADMIN_ID=1166455103
